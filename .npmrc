# Supply-chain security hardening for pnpm installs.

# Lock the registry to the public npm registry — prevents typosquatting redirects.
registry=https://registry.npmjs.org/

# Allow caret ranges to keep deps current within a major.
save-exact=false

# Don't fail on peer dependency conflicts (Cloudflare Pages tolerates these).
strict-peer-dependencies=false

# Enable package-lock integrity verification.
package-lock=true

# Prevent lifecycle scripts from running during install (defence against
# supply-chain attacks). Re-enable selectively with `pnpm approve-builds`.
ignore-scripts=true

# Engine strictness — fail if Node version doesn't match engines field.
engine-strict=true
